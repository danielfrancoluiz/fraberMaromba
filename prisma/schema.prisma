generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id         String   @id @default(uuid())
  nome       String
  email      String   @unique
  senha      String
  role       String   // "professor" ou "aluno"
  status     String   @default("ativo_plataforma")
  /// Plano contratado pelo professor (assinatura da plataforma). Aluno usa Aluno.planoId.
  planoId    String?
  /// Data em que o plano do professor deixa de valer.
  planoVenceEm DateTime?
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relações
  professorAlunos  Aluno[]   @relation("ProfessorAlunos")
  alunoVinculo     Aluno?    @relation("UsuarioAluno")
  convitesGerados  Convite[] @relation("ProfessorConvites")
  treinos          Treino[]  @relation("ProfessorTreinos")
  templates        TreinoTemplate[] @relation("ProfessorTemplates")
  exerciciosCatalogo ExercicioCatalogo[] @relation("ProfessorExerciciosCatalogo")
  tokensRedefinirSenha TokenRedefinirSenha[]
}

model TokenRedefinirSenha {
  id        String   @id @default(uuid())
  usuarioId String
  token     String   @unique
  expiraEm  DateTime
  usado     Boolean  @default(false)
  criadoEm  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

model Aluno {
  id           String   @id @default(uuid())
  usuarioId    String?  @unique
  professorId  String
  nomeCompleto String
  cpf          String   @unique
  email        String
  telefone     String
  sexo         String
  dataNascimento String
  peso         Float
  altura       Float
  objetivo     String
  /// Compat: "modulos_1" | "modulos_2" | "modulos_3" | ""
  planoId      String
  /// Módulos contratados: musculacao | corrida | nutricao
  modulosAtivos String[] @default([])
  /// Data em que o plano do aluno deixa de valer.
  planoVenceEm DateTime?
  status       String   @default("inativo")
  dataCadastro DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  professor    Usuario  @relation("ProfessorAlunos", fields: [professorId], references: [id])
  usuario      Usuario? @relation("UsuarioAluno", fields: [usuarioId], references: [id])
  treinos      Treino[] @relation("AlunoTreinos")
  sessoes      TreinoSessao[] @relation("AlunoSessoes")
  pagamentos   Pagamento[]
  checkins     Checkin[]
  medicoes     MedicaoFisica[]
}

model Treino {
  id          String   @id @default(uuid())
  alunoId     String
  professorId String
  nome        String
  descricao   String?
  objetivo    String?
  diaSemana   String
  dataCriacao DateTime @default(now())

  aluno       Aluno    @relation("AlunoTreinos", fields: [alunoId], references: [id])
  professor   Usuario  @relation("ProfessorTreinos", fields: [professorId], references: [id])
  exercicios  Exercicio[]
  sessoes     TreinoSessao[] @relation("TreinoSessoes")
}

model ExercicioCatalogo {
  id               String   @id @default(uuid())
  professorId      String?
  nome             String
  slug             String   @unique
  grupoMuscular    String
  subGrupoMuscular String?
  equipamento      String?
  dificuldade      String?
  descricao        String?
  gifUrl           String?
  imagemUrl        String?
  seriesPadrao     Int      @default(3)
  repeticoesPadrao Int      @default(12)
  descansoPadrao   Int      @default(60)
  unilateral       Boolean  @default(false)
  ativo            Boolean  @default(true)
  criadoEm         DateTime @default(now())

  professor            Usuario?            @relation("ProfessorExerciciosCatalogo", fields: [professorId], references: [id], onDelete: SetNull)
  exerciciosTreino     Exercicio[]
  exerciciosTemplate   ExercicioTemplate[]
}

model Exercicio {
  id                  String  @id @default(uuid())
  treinoId            String
  exercicioCatalogoId String?
  nome                String
  series              Int
  repeticoes          Int
  /// Quando preenchido (ex.: [12,10,8]), cada série tem reps próprias. Vazio = todas iguais a `repeticoes`.
  repeticoesPorSerie  Int[]   @default([])
  grupoMuscular       String?
  observacao          String?
  restSeconds         Int     @default(60)
  ordem               Int     @default(0)

  treino    Treino             @relation(fields: [treinoId], references: [id], onDelete: Cascade)
  catalogo  ExercicioCatalogo? @relation(fields: [exercicioCatalogoId], references: [id], onDelete: SetNull)
  seriesSessao TreinoSessaoSerie[] @relation("ExercicioSeriesSessao")
}

model TreinoTemplate {
  id          String   @id @default(uuid())
  professorId String
  nome        String
  descricao   String?
  dataCriacao DateTime @default(now())

  professor   Usuario  @relation("ProfessorTemplates", fields: [professorId], references: [id])
  exercicios  ExercicioTemplate[]
}

model ExercicioTemplate {
  id                  String  @id @default(uuid())
  templateId          String
  exercicioCatalogoId String?
  nome                String
  series              Int
  repeticoes          Int
  repeticoesPorSerie  Int[]   @default([])
  grupoMuscular       String?
  observacao          String?
  restSeconds         Int     @default(60)
  ordem               Int     @default(0)

  template  TreinoTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  catalogo  ExercicioCatalogo?  @relation(fields: [exercicioCatalogoId], references: [id], onDelete: SetNull)
}

model TreinoSessao {
  id              String    @id @default(uuid())
  treinoId        String
  alunoId         String
  iniciadoEm      DateTime  @default(now())
  finalizadoEm    DateTime?
  duracaoSegundos Int?
  status          String    @default("em_andamento")

  treino  Treino              @relation("TreinoSessoes", fields: [treinoId], references: [id], onDelete: Cascade)
  aluno   Aluno               @relation("AlunoSessoes", fields: [alunoId], references: [id], onDelete: Cascade)
  series  TreinoSessaoSerie[]
}

model TreinoSessaoSerie {
  id                     String  @id @default(uuid())
  sessaoId               String
  exercicioId            String
  numeroSerie            Int
  concluida              Boolean @default(false)
  substitutoCatalogoId   String?

  sessao    TreinoSessao @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  exercicio Exercicio    @relation("ExercicioSeriesSessao", fields: [exercicioId], references: [id], onDelete: Cascade)

  @@unique([sessaoId, exercicioId, numeroSerie])
}

model Convite {
  id           String   @id @default(uuid())
  token        String   @unique @default(uuid())
  professorId  String
  email        String?
  usado        Boolean  @default(false)
  dataCriacao  DateTime @default(now())

  professor    Usuario  @relation("ProfessorConvites", fields: [professorId], references: [id])
}

model Pagamento {
  id              String   @id @default(uuid())
  /// Null quando o professor paga a própria assinatura da plataforma.
  alunoId         String?
  professorId     String
  valor           Float
  status          String   @default("pendente")
  planoId         String
  /// Módulos cobrados neste pagamento (aluno).
  modulos         String[] @default([])
  metodoPagamento String?
  stripeSessionId String?  @unique
  stripePaymentIntentId String? @unique
  dataVencimento  DateTime
  dataPagamento   DateTime?
  criadoEm        DateTime @default(now())

  aluno           Aluno?   @relation(fields: [alunoId], references: [id])
}

/// Catálogo de planos/preços. O checkout lê `valorCentavos` daqui.
model Plano {
  id               String   @id
  nome             String
  valorCentavos    Int
  diasValidade     Int
  permiteCheckout  Boolean  @default(true)
  ativo            Boolean  @default(true)
  ordem            Int      @default(0)
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt
}

/// Configurações globais da plataforma (singleton id = "default").
model ConfigApp {
  id                  String   @id @default("default")
  /// Quantos dias antes do vencimento mostrar aviso no dashboard.
  diasAvisoVencimento Int      @default(5)
  atualizadoEm        DateTime @updatedAt
}

/// Preço mensal conforme quantidade de módulos escolhidos (1, 2 ou 3).
model PrecoPacoteModulos {
  quantidade    Int     @id
  valorCentavos Int
  diasValidade  Int     @default(30)
  ativo         Boolean @default(true)
  atualizadoEm  DateTime @updatedAt
}

model Checkin {
  id         String   @id @default(uuid())
  alunoId    String
  treinoId   String?
  dataHora   DateTime @default(now())
  observacao String?

  aluno      Aluno    @relation(fields: [alunoId], references: [id])
}

model MedicaoFisica {
  id             String   @id @default(uuid())
  alunoId        String
  professorId    String
  peso           Float?
  cintura        Float?
  quadril        Float?
  bracoDireito   Float?
  bracoEsquerdo  Float?
  coxaDireita    Float?
  coxaEsquerda   Float?
  observacao     String?
  dataMedicao    DateTime @default(now())
  criadoEm       DateTime @default(now())

  aluno          Aluno    @relation(fields: [alunoId], references: [id])
}
